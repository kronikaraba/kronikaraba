# Vercel Dashboard → Storage → Blob → Connect → otomatik eklenir
BLOB_READ_WRITE_TOKEN=

# Admin API Token — yazma işlemleri için gerekli
# Vercel Dashboard → Settings → Environment Variables → ADMIN_API_TOKEN
ADMIN_API_TOKEN=

# (Opsiyonel) İzin verilen origin'ler, virgülle ayrılmış
# Belirtilmezse tüm origin'lere izin verilir
# ALLOWED_ORIGINS=https://kronikaraba.vercel.app,https://kronikariza.com

# Yerel geliştirmede: npx vercel dev
# Üretim: https://kronikaraba.vercel.app/api/upload
